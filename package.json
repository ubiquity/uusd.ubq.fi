{
  "name": "uusd.ubq.fi",
  "module": "src/app.ts",
  "type": "module",
  "scripts": {
    "dev": "deno task build:watch & deno task serve:dev",
    "build": "deno task build",
    "build:watch": "deno task build:watch",
    "serve": "deno task serve",
    "serve:dev": "deno task serve:dev",
    "serve:bun": "bun run serve.ts",
    "serve:bun:dev": "bun run serve-dev.ts",
    "browser:open": "/Applications/Brave\\ Browser.app/Contents/MacOS/Brave\\ Browser --remote-debugging-port=9222",
    "diamond": "bun run tools/diamond-reader.ts",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write 'src/**/*.ts'",
    "format:check": "prettier --check 'src/**/*.ts'",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@eslint/js": "^9.33.0",
    "@types/bun": "latest",
    "@typescript-eslint/eslint-plugin": "^8.39.1",
    "@typescript-eslint/parser": "^8.39.1",
    "esbuild": "^0.25.0",
    "eslint": "^9.33.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "globals": "^16.3.0",
    "prettier": "^3.6.2",
    "typescript": "^5.9.2"
  },
  "dependencies": {
    "@cowprotocol/cow-sdk": "^7.2.7",
    "@cowprotocol/sdk-viem-adapter": "^0.3.0",
    "@ubiquity-dao/permit2-rpc-client": "^0.1.2",
    "commander": "^14.0.0",
    "dotenv": "^16.5.0",
    "viem": "^2.31.2"
  }
}
